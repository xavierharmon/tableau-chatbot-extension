<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.yourcompany.data-chat" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>AI-powered chat interface to query your Excel data using Claude, directly inside Tableau.</description>
    <author
      name="Your Name"
      email="you@yourcompany.com"
      organization="Your Company"
      website="https://yourcompany.com"/>
    <min-api-version>1.7</min-api-version>
    <source-location>
      <!--
        STEP 1 — LOCAL DEV (Tableau Desktop, no server needed):
          Uncomment the line below and run: npx serve . OR python -m http.server 8765
          Then load this .trex file from Tableau Desktop.
      -->
      <url>http://localhost:8765/index.html</url> 

      <!--
        STEP 2 — GITHUB PAGES (free HTTPS hosting):
          1. Push this folder to a GitHub repo
          2. Go to repo Settings → Pages → Deploy from main branch / root
          3. Replace YOUR_USERNAME and YOUR_REPO below
          4. Wait ~60 seconds for GitHub to deploy, then reload
      -->
      <!-- <url>https://xavierharmon.github.io/tableau-chatbot-extension/index.html</url> -->

      <!--
        STEP 3 — TABLEAU SERVER (production):
          Replace with your internal hosting URL and add it to the
          Tableau Server allow-list under Settings → Extensions.
      -->
      <!-- <url>https://extensions.yourcompany.com/data-chat/index.html</url> -->
    </source-location>
    <icon>iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAYAAAAf8/9hAAAACXBIWXMAAAsTAAALEwEAmpwYAAAA</icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">Data Chat — Claude AI</text>
    </resource>
  </resources>
</manifest>
